---
import { getEntry, getEntries } from "astro:content"
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import "../../../styles/global.css"
import BaseLayout from "../../../layouts/BaseLayout.astro"

const { categoryId, productId } = Astro.params;
const product = await getEntry('products', `${categoryId}/${productId}`)!
const extras = await getEntries(product.data.extras)
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/products/**/*.png')
const imagePath = `/src/assets/products/${product.id}.png`

export async function getStaticPaths() {
  return [
    { params: { categoryId: 'sicak-kahve', productId: 'americano' } },
    { params: { categoryId: 'sicak-kahve', productId: 'latte' } },
    { params: { categoryId: 'soguk-kahve', productId: 'iced-americano' } }
  ]
}
---

<BaseLayout>
  
  <div class="p-2 flex flex-col gap-2">
    {images[imagePath] &&
      <Image src={images[imagePath]()} alt={product.id} class="rounded-lg w-full object-cover object-center" />
    }
    <div class="rounded-2xl shadow-lg p-4 bg-cream border border-terracotta">
      <div class="flex justify-between">
        <div class="text-terracottaDark font-semibold tracking-wider text-2xl">{product.data.title}</div>
        <div class="text-terracottaDark font-semibold tracking-wider text-2xl">₺{product.data.price}</div>
      </div>
      <div class="text-muted text-sm">product desription...</div>
      
      <div class="flex flex-col gap-4 mt-4">

        {extras.map(extra => (
          <div>
            <h2 class="text-lg text-terracotta font-semibold"><span class="text-2xl text-terracottaDark">❧</span> {extra.data.title}</h2>
            <ul>
              {extra.data.items.map(item => (
                <li class="flex justify-between">
                  <span>{item.title}</span>
                  <span class="text-olive text-lg">+ ₺{item.price}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      
      </div>
    
    </div>
  </div>

</BaseLayout>